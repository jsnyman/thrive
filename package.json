{
  "name": "recycling-swap-shop",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.10.0",
  "engines": {
    "node": ">=22.18.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "npm run test:web && npm run test:shared && npm run test:api",
    "test:web": "vitest run --config apps/web/vitest.config.ts --passWithNoTests",
    "test:web:watch": "vitest --config apps/web/vitest.config.ts",
    "test:shared": "vitest run --config packages/shared/vitest.config.ts --passWithNoTests",
    "test:shared:watch": "vitest --config packages/shared/vitest.config.ts",
    "test:api": "jest --config apps/api/jest.config.cjs --passWithNoTests",
    "start:api": "npx tsx apps/api/src/start.ts",
    "seed:staff": "npx tsx apps/api/src/scripts/seed-staff.ts",
    "projections:install": "npx tsx apps/api/src/projections/install.ts",
    "test:e2e": "playwright test --pass-with-no-tests",
    "typecheck": "tsc -p apps/web/tsconfig.json && tsc -p apps/api/tsconfig.json && tsc -p packages/shared/tsconfig.json",
    "prisma:generate": "cd apps/api && npx prisma generate",
    "prisma:migrate": "cd apps/api && npx prisma migrate dev --name init",
    "prisma:studio": "cd apps/api && npx prisma studio",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.5",
    "@playwright/test": "^1.48.2",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-vitest": "^0.5.4",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jsdom": "^24.1.0",
    "lint-staged": "^15.2.7",
    "msw": "^2.4.4",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "ts-jest": "^29.2.5",
    "typescript": "^5.5.4",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@prisma/client": "^7.4.1",
    "prisma": "^7.4.1"
  }
}
